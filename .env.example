# === INFERENCE BACKEND ===
# OpenRouter (recommended — access to all OSS and proprietary models, pay per token)
COUNCIL_BASE_URL=https://openrouter.ai/api/v1
COUNCIL_API_KEY=your_openrouter_key_here

# Local Ollama alternative
# COUNCIL_BASE_URL=http://localhost:11434/v1
# COUNCIL_API_KEY=ollama

# === RESEARCH ===
# Model used for synthesizing Tavily search results into structured JSON context
# OpenRouter OSS: z-ai/glm-5.1  |  Local Ollama: qwen3.5:27b
RESEARCH_MODEL=z-ai/glm-5.1
RESEARCH_MODEL_FALLBACK=qwen/qwen3.5-397b-a17b
TAVILY_API_KEY=your_tavily_api_key_here

# === DISTRIBUTION ===
# Twitter/X — requires Elevated Access at developer.twitter.com
# Warning: Elevated Access approval can take days. Apply immediately.
# Fallback if rejected: copy thread from runs/*_thread.json and post manually.
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# Substack URL for linking from tweets (set this once you create your publication)
SUBSTACK_URL=https://yourname.substack.com
